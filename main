-- ==================== SELL TAB ====================
SellTab:CreateSection("💸 Auto Sell")

SellTab:CreateLabel("Selecione Pets para Vender:")
local sellPetsFormatted = {}
for rarity, pets in pairs(petData) do
    for _, pet in ipairs(pets) do
        table.insert(sellPetsFormatted, "[" .. rarity .. "] " .. pet)
    end
end

SellTab:CreateDropdown({
    Name = "Pets para Vender",
    Options = sellPetsFormatted,
    Multi = true,
    Default = {},
    Callback = function(values)
        targetSellPets = {}
        for _, v in ipairs(values) do
            local petName = v:match("%]%s(.+)")
            if petName then
                targetSellPets[petName] = true
            end
        end
    end
})

SellTab:CreateToggle({
    Name = "Auto Sell",
    CurrentValue = false,
    Callback = function(v)
        autoSellEnabled = v
        if v then
            startAutoSell()
        end
    end
})

-- ==================== INFO TAB ====================
InfoTab:CreateSection("ℹ️ Informações")

