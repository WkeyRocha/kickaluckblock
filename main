-- ==================== FUNÇÕES DO SISTEMA ORIGINAL ====================
local function teleportTo(cframe)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = cframe end
end

local function tweenMove(hrp, humanoid, targetPos)
    if not (hrp and humanoid and humanoid.Health > 0) then return end
    local targetCFrame = CFrame.new(targetPos.X, fixedY, targetPos.Z)
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local speed = (useCustomSpeed and customSpeed) or math.max(humanoid.WalkSpeed, 50)
    local tweenTime = distance / speed
    hrp.Anchored = true
    local tween = TweenService:Create(hrp, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
    if hrp and hrp.Parent then hrp.Anchored = false end
end

local function forceClick(button)
    if not button or not button.Parent then return end
    if getconnections then
        for _, c in pairs(getconnections(button.MouseButton1Down)) do c:Fire() end
        for _, c in pairs(getconnections(button.MouseButton1Click)) do c:Fire() end
    end
    pcall(function() button:Activate() end)
end

local function sendWebhook(title, description, color, forceOverride)
    if webhookURL == "" then return end
    if not webhookEnabled and not forceOverride then return end
    local httpRequest = request or http_request or (syn and syn.request)
    if httpRequest then
        local payload = {embeds = {{title = title, description = description, color = color, footer = {text = "ROCHA HUB | " .. os.date("%X")}}}}
        task.spawn(function()
            pcall(function()
                httpRequest({Url = webhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload)})
            end)
        end)
    end
end

-- ==================== AUTO KICK (ORIGINAL COMPLETO) ====================
local function startAutoKick()
    autoKickCounter = autoKickCounter + 1
    local currentCounter = autoKickCounter
    task.spawn(function()
        while autoKickEnabled and currentCounter == autoKickCounter do
            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local humanoid = char and char:FindFirstChild("Humanoid")
                if not (hrp and humanoid and humanoid.Health > 0) then return end

                local kickReady = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild("KickReady")
                if not kickReady then return end
                local kickCFrame = (kickReady:IsA("BasePart") and kickReady.CFrame) or kickReady:GetPivot()

                if (hrp.Position - kickCFrame.Position).Magnitude > 5 then
                    teleportTo(kickCFrame + Vector3.new(0, 3, 0))
                end

                task.wait(0.5)
                local startPos = hrp.Position
                local wasTeleported = false
                local HUD = PlayerGui:FindFirstChild("HUD")

                for i = 1, 150 do
                    task.wait(0.1)
                    if not char or not char.Parent or humanoid.Health <= 0 then return end
                    if (hrp.Position - startPos).Magnitude > 30 then
                        wasTeleported = true
                        break
                    end
                    local kickButton = HUD and HUD:FindFirstChild("KickButton")
                    if kickButton and kickButton.Visible then
                        Network.rev_KickEvent:FireServer(kickValues[kickMode] or 1)
                        task.wait(0.5)
                    end
                end

                if not wasTeleported then return end
                task.wait(0.5)

                local monsterFound = false
                local spawnedMonster = nil
                for i = 1, 40 do
                    task.wait(0.2)
                    for _, obj in pairs(workspace.Debris:GetChildren()) do
                        if obj:IsA("Model") and obj.PrimaryPart then
                            local dist = (obj.PrimaryPart.Position - hrp.Position).Magnitude
                            if dist < 60 then
                                monsterFound = true
                                spawnedMonster = obj
                                break
                            end
                        end
                    end
                    if monsterFound then break end
                end

                if monsterFound and spawnedMonster then
                    task.wait(0.5)

                    local isMutationDesired = false
                    local hasMutationFilter = false
                    for mutation, enabled in pairs(targetMutations) do
                        if enabled then
                            hasMutationFilter = true
                            if mutation == "Normal" or string.find(string.lower(spawnedMonster.Name), string.lower(mutation)) then
                                isMutationDesired = true
                                break
                            end
                        end
                    end

                    local isPetDesired = false
                    local hasPetFilter = false
                    for petName, enabled in pairs(targetPets) do
                        if enabled then
                            hasPetFilter = true
                            if string.find(string.lower(spawnedMonster.Name), string.lower(petName)) then
                                isPetDesired = true
                                break
                            end
                        end
                    end

                    local shouldFlee = (hasMutationFilter and not isMutationDesired) or (hasPetFilter and not isPetDesired)

                    if shouldFlee then
                        local waves = workspace:FindFirstChild("Waves")
                        local wavePos = waves and (waves.Position or waves:GetPivot().Position)
                        if wavePos then tweenMove(hrp, humanoid, wavePos) end
                    elseif spawnedMonster and not spawnedMonster:GetAttribute("WebhookSent") then
                        spawnedMonster:SetAttribute("WebhookSent", true)
                        local monsterName = spawnedMonster.Name
                        local mutationStr = "Normal"
                        sendWebhook("👀 Target Found!", "**Pet:** "..monsterName.."\n**Player:** "..player.Name, 3447003, false)
                        tweenMove(hrp, humanoid, kickCFrame.Position)
                    end
                end
            end)
            task.wait(0.4)
        end
    end)
end

-- ==================== AUTO TRAIN (ORIGINAL) ====================
local function startAutoTrain()
    autoTrainCounter = autoTrainCounter + 1
    local currentCounter = autoTrainCounter
    task.spawn(function()
        while autoTrainEnabled and currentCounter == autoTrainCounter do
            pcall(function()
                local char = player.Character
                local humanoid = char and char:FindFirstChild("Humanoid")
                local currentTool = char and char:FindFirstChildOfClass("Tool")
                if not currentTool and humanoid then
                    local backpack = player:FindFirstChild("Backpack")
                    for _, tool in pairs(backpack:GetChildren()) do
                        if tool:IsA("Tool") then
                            humanoid:EquipTool(tool)
                            break
                        end
                    end
                elseif currentTool then
                    currentTool:Activate()
                end
            end)
            task.wait(0.08)
        end
    end)
end

-- ==================== AUTO COLLECT & SELL ====================
local function startAutoCollect()
    task.spawn(function()
        while autoCollectEnabled do
            if lockedPlot then
                local buttons = lockedPlot:FindFirstChild("Buttons")
                if buttons then
                    for i = 1, 30 do
                        local slot = buttons:FindFirstChild("Slot" .. i)
                        if slot then
                            local part = slot:IsA("BasePart") and slot or slot:FindFirstChildWhichIsA("BasePart")
                            if part then
                                teleportTo(part.CFrame + Vector3.new(0,2,0))
                                Network.rev_B_Collect:FireServer(i)
                            end
                        end
                    end
                end
            end
            task.wait(1.4)
        end
    end)
end

local function startAutoSell()
    task.spawn(function()
        while autoSellEnabled do
            pcall(function()
                local backpack = player:FindFirstChild("Backpack")
                local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
                if backpack and humanoid then
                    for _, tool in pairs(backpack:GetChildren()) do
                        if targetSellPets[tool.Name] then
                            humanoid:EquipTool(tool)
                            task.wait(0.2)
                            ReplicatedStorage.Shared.Packages.Network.ref_B_Sell:InvokeServer()
                            task.wait(0.3)
                        end
                    end
                end
            end)
            task.wait(1)
        end
    end)
end

-- ==================== RAYFIELD INTERFACE ====================
local Window = Rayfield:CreateWindow({
    Name = "ROCHA HUB",
    LoadingTitle = "ROCHA HUB",
    LoadingSubtitle = "Kick a Lucky Block",
    ConfigurationSaving = {Enabled = true, FolderName = "RochaHub", FileName = "Config"}
})

local MainTab = Window:CreateTab("🏠 Main")
local CollectTab = Window:CreateTab("💰 Collect")
