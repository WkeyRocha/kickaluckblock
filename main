-- ==================== ANTI-CHEAT BYPASS SYSTEMS ====================

-- 1️⃣ PHYSICS SPOOFING
local PhysicsSpoof = {
    enabled = false,
    randomDelay = function() return math.random(50, 200) / 1000 end,
    randomVelocity = function() return math.random(-10, 10) / 100 end,
    
    apply = function(self, hrp)
        if not self.enabled or not hrp then return end
        pcall(function()
            -- Adicionar ruído físico aleatório
            hrp.Velocity = hrp.Velocity + Vector3.new(
                self.randomVelocity(),
                self.randomVelocity(),
                self.randomVelocity()
            )
        end)
    end
}

-- 2️⃣ HUMANOID STATE MASKING
local HumanoidSpoof = {
    enabled = false,
    mask = function(self, hum)
        if not self.enabled or not hum then return end
        pcall(function()
            -- Mascarar estado humanóide
            hum:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Running, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        end)
    end
}

-- 3️⃣ NETWORK DELAY SIMULATION
local NetworkDelay = {
    baseDelay = 0.05,
    randomDelay = function() return math.random(20, 80) / 1000 end,
    
    apply = function(self)
        return self.baseDelay + self.randomDelay()
    end
}

-- 4️⃣ MOVEMENT PATTERN RANDOMIZATION
local MovementPattern = {
    lastDirection = Vector3.new(0, 0, 0),
    changeThreshold = 0.3,
    
    getRandomDirection = function(self, targetPos, currentPos)
        local direction = (targetPos - currentPos).Unit
        
        -- Adicionar variação aleatória ao movimento
        if math.random() < self.changeThreshold then
            direction = direction + Vector3.new(
                math.random(-30, 30) / 100,
                0,
                math.random(-30, 30) / 100
            )
        end
        
        self.lastDirection = direction
        return direction.Unit
    end
}

-- 5️⃣ ANIMATION DESYNC (evita detectar animações suspeitas)
local AnimationDesync = {
    enabled = false,
    desyncAmount = 0.3,
    
    apply = function(self, char)
        if not self.enabled or not char then return end
        pcall(function()
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                for _, anim in pairs(humanoid:GetPlayingAnimationTracks()) do
                    -- Dessincroniazar animação
                    anim:AdjustSpeed(1 + self.desyncAmount)
                end
            end
        end)
    end
}

-- 6️⃣ TELEPORT SPOOFING (simula movimento gradual) - VELOCIDADE EQUILIBRADA
local TeleportSpoof = {
    stepDistance = 10,  -- Equilibrado entre velocidade e suavidade
    stepDelay = 0.03,   -- Delay moderado para não ser instantâneo
    
    gradualTP = function(self, hrp, targetCFrame)
        if not (hrp and hrp.Parent) then return false end
        
        local startPos = hrp.Position
        local targetPos = targetCFrame.Position
        local distance = (targetPos - startPos).Magnitude
        local steps = math.ceil(distance / self.stepDistance)
        
        for i = 1, steps do
            if not (hrp and hrp.Parent) then break end
            
            local progress = i / steps
            local intermediateCFrame = CFrame.new(startPos:Lerp(targetPos, progress)) * targetCFrame.Rotation
            
            pcall(function()
                hrp.CFrame = intermediateCFrame
                hrp.Velocity = Vector3.new(0, 0, 0)
            end)
            
            task.wait(self.stepDelay)
        end
        
        return true
    end
}

-- 7️⃣ REQUEST TIMING RANDOMIZATION
local RequestTiming = {
    baseDelay = 0.1,
    variance = 0.05,
    
    getDelay = function(self)
        local randomVariance = (math.random() - 0.5) * 2 * self.variance
        return self.baseDelay + randomVariance
    end
}

-- 8️⃣ DETECTION EVASION (evita padrões óbvios)
local DetectionEvasion = {
    perfectKickCount = 0,
    lastKickTime = 0,
    minTimeBetweenKicks = 2, -- MODIFICADO: 2 segundos entre chutes
    
    shouldKick = function(self)
        local currentTime = tick()
        
        -- Evitar múltiplos chutes perfeitos em sequência
        if currentTime - self.lastKickTime < self.minTimeBetweenKicks then
            return false
        end
        
        -- Variar modo de chute para não ser óbvio
        if self.perfectKickCount > 3 then
            self.perfectKickCount = 0
            return false
        end
        
        self.lastKickTime = currentTime
        self.perfectKickCount = self.perfectKickCount + 1
        return true
    end,
    
    getRandomKickMode = function(self)
        if math.random() < 0.8 then
            return "Perfect"
        else
            local modes = {"Excellent", "Great", "Perfect"}
            return modes[math.random(#modes)]
        end
    end
}

-- 9️⃣ ANTI-AFK SYSTEM
local AntiAFK = {
    enabled = false,
    lastActivityTime = tick(),
    inactivityThreshold = 600, -- 10 minutos
    
    getRandomMovement = function(self)
        return Vector3.new(
            math.random(-50, 50) / 100,
            0,
            math.random(-50, 50) / 100
        )
    end,
    
    moveRandomly = function(self, hrp, hum)
        if not (hrp and hum and hum.Health > 0) then return end
        
        -- Movimento aleatório pequeno
        local randomDir = self:getRandomMovement()
        hum:Move(randomDir, true)
    end,
    
    jumpRandomly = function(self, hum)
        if not (hum and hum.Health > 0) then return end
        
        -- Pular aleatoriamente
        if math.random() < 0.3 then
            hum:Jump()
        end
    end,
    
    turnPlayer = function(self, hrp)
        if not hrp then return end
        
        -- Girar player aleatoriamente
        local randomAngle = math.random(0, 360)
        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(randomAngle), 0)
    end
}

