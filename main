local function LoadPetsForRarity(rarity)
    for _, child in pairs(RightPanel:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
    local pets = petData[rarity]
    
    for _, petName in ipairs(pets) do
        local PetRow = Instance.new("Frame")
        PetRow.Parent = RightPanel
        PetRow.BackgroundColor3 = Theme.Bg
        PetRow.Size = UDim2.new(1, -15, 0, 40)
        Instance.new("UICorner", PetRow).CornerRadius = UDim.new(0, 6)

        local PetLabel = Instance.new("TextLabel")
        PetLabel.Parent = PetRow
        PetLabel.BackgroundTransparency = 1
        PetLabel.Position = UDim2.new(0, 15, 0, 0)
        PetLabel.Size = UDim2.new(1, -60, 1, 0)
        PetLabel.Font = Enum.Font.GothamSemibold
        PetLabel.Text = petName
        PetLabel.TextColor3 = Theme.Text
        PetLabel.TextSize = 14
        PetLabel.TextXAlignment = Enum.TextXAlignment.Left

        local ToggleBtn = Instance.new("TextButton")
        ToggleBtn.Parent = PetRow
        ToggleBtn.BackgroundColor3 = targetPets[petName] and Theme.Accent or Theme.Stroke
        ToggleBtn.Position = UDim2.new(1, -40, 0.5, -12)
        ToggleBtn.Size = UDim2.new(0, 24, 0, 24)
        ToggleBtn.Text = ""
        Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 6)

        ToggleBtn.MouseButton1Click:Connect(function()
            targetPets[petName] = not targetPets[petName]
            ToggleBtn.BackgroundColor3 = targetPets[petName] and Theme.Accent or Theme.Stroke
        end)
    end
    RightPanel.CanvasSize = UDim2.new(0, 0, 0, #pets * 46)
end

for _, rarity in ipairs(rarityList) do
