InfoTab:CreateLabel("━━━━━━━━━━━━━━━━━━━━")
InfoTab:CreateLabel("Pets Selecionados: 0")
InfoTab:CreateLabel("Mutações Selecionadas: 0")

local function updateInfoTab()
    local selectedPets = 0
    local selectedMutations = 0
    
    for _, enabled in pairs(targetPets) do
        if enabled then selectedPets = selectedPets + 1 end
    end
    
    for _, enabled in pairs(targetMutations) do
        if enabled then selectedMutations = selectedMutations + 1 end
    end
    
    InfoTab:CreateLabel("Pets Selecionados: " .. selectedPets)
    InfoTab:CreateLabel("Mutações Selecionadas: " .. selectedMutations)
end

