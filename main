-- ==================== MAIN TAB ====================
MainTab:CreateSection("🎯 Alvos")

-- ==================== PETS SECTION COM CHECKBOXES ====================
MainTab:CreateLabel("Selecione os Pets:")

local petCheckboxes = {}
local petToggleStates = {}

for rarity, pets in pairs(petData) do
    MainTab:CreateLabel("━━━ " .. rarity .. " ━━━")
    for _, pet in ipairs(pets) do
        local label = "[" .. rarity .. "] " .. pet
        petCheckboxes[label] = {pet = pet, rarity = rarity}
        petToggleStates[pet] = false
        
        MainTab:CreateToggle({
            Name = pet,
            CurrentValue = false,
            Callback = function(value)
                petToggleStates[pet] = value
                targetPets[pet] = value
                if value then
                    print("✅ Pet selecionado: " .. pet)
                else
                    print("❌ Pet removido: " .. pet)
                end
            end
        })
    end
end

-- ==================== MUTATIONS SECTION COM CHECKBOXES ====================
MainTab:CreateSection("🧬 Mutações")
MainTab:CreateLabel("Selecione as Mutações:")

local mutationToggleStates = {}
for _, mutation in ipairs(mutationList) do
    mutationToggleStates[mutation] = false
    MainTab:CreateToggle({
        Name = mutation,
        CurrentValue = false,
        Callback = function(value)
            mutationToggleStates[mutation] = value
            targetMutations[mutation] = value
            if value then
                print("✅ Mutação selecionada: " .. mutation)
            else
                print("❌ Mutação removida: " .. mutation)
            end
        end
    })
end

