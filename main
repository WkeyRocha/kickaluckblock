StatsTab:CreateSection("📊 Estatísticas")

local statsLabel = StatsTab:CreateLabel("Atualizando...")

local function updateStats()
    task.spawn(function()
        while true do
            task.wait(1)
            pcall(function()
                local char = player.Character
                local hum = char and char:FindFirstChild("Humanoid")
                local sessionTime = math.floor(tick() - state.sessionStartTime)
                local hours = math.floor(sessionTime / 3600)
                local minutes = math.floor((sessionTime % 3600) / 60)
                local seconds = sessionTime % 60
                
                -- Calcular tempo até próximo chute
                local timeSinceKick = tick() - state.lastKickTime
                local timeUntilNextKick = math.max(0, state.kickCooldown - timeSinceKick)
                
                local info = "⏱️ Tempo: " .. string.format("%02d:%02d:%02d", hours, minutes, seconds) .. "\n\n"
                info = info .. "🎯 Chutes: " .. state.totalKicks .. "\n"
                info = info .. "💰 Coletados: " .. state.totalCollected .. "\n"
                info = info .. "⬆️ Upgrades: " .. state.totalUpgrades .. "\n"
                info = info .. "🧠 Brainrot: " .. state.totalBrainrot .. "\n\n"
                
                -- Mostrar cooldown de chute
                if state.autoKick then
                    info = info .. "⏳ Próx. Chute: " .. string.format("%.1f", timeUntilNextKick) .. "s\n\n"
                end
                
                info = info .. "Estado: "
                if state.autoKick then info = info .. "[Chute✓] " end
                if state.autoTrain then info = info .. "[Treino✓] " end
                if state.autoCollect then info = info .. "[Coleta✓] " end
                if state.autoUpgrade then info = info .. "[Upgrade✓] " end
                if state.autoBuyWeight then info = info .. "[Compra✓] " end
                if state.autoBrainrot then info = info .. "[Brainrot✓] " end
                if state.antiAFK then info = info .. "[AntiAFK✓] " end
                
                if not (state.autoKick or state.autoTrain or state.autoCollect or state.autoUpgrade or state.autoBuyWeight or state.autoBrainrot or state.antiAFK) then
                    info = info .. "[Standby]"
                end
                
                if hum then
                    info = info .. "\n\nHP: " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
                end
                
                statsLabel:Set(info)
            end)
        end
    end)
end

updateStats()

