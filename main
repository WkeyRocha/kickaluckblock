CollectTab:CreateToggle({
    Name = "💰 Auto Collect",
    CurrentValue = false,
    Callback = function(v)
        autoCollectEnabled = v
        if v then
            if not lockedPlot then
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local closest = math.huge
                    for _, plot in pairs(workspace.Plots:GetChildren()) do
                        local dist = (hrp.Position - plot:GetPivot().Position).Magnitude
                        if dist < closest then closest, lockedPlot = dist, plot end
                    end
                end
            end
            startAutoCollect()
        end
    end
})

SellTab:CreateSection("💸 Brainrots para Vender")
for _, rarity in ipairs(rarityList) do
    SellTab:CreateSection(rarity)
    for _, pet in ipairs(petData[rarity]) do
        SellTab:CreateToggle({
            Name = pet,
            CurrentValue = false,
            Callback = function(v) targetSellPets[pet] = v end
        })
    end
end
SellTab:CreateToggle({
    Name = "Auto Sell",
    CurrentValue = false,
    Callback = function(v)
        autoSellEnabled = v
        if v then startAutoSell() end
    end
})

