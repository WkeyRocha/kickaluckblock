-- ==================== UTILITÁRIOS ====================
local function teleportTo(cframe)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = cframe end
end

local function tweenMove(hrp, humanoid, targetPos)
    if not (hrp and humanoid and humanoid.Health > 0) then return end
    local targetCFrame = CFrame.new(targetPos.X, fixedY, targetPos.Z)
    local distance = (hrp.Position - targetCFrame.Position).Magnitude
    local speed = (useCustomSpeed and customSpeed) or math.max(humanoid.WalkSpeed, 50)
    hrp.Anchored = true
    local tween = TweenService:Create(hrp, TweenInfo.new(distance / speed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
    if hrp and hrp.Parent then hrp.Anchored = false end
end

