-- ==================== UTILITY FUNCTIONS ====================

local function debugLog(message)
    if gameConfig.debugMode then
        print("[LBH-BYPASS] " .. message)
    end
end

local function notify(title, content, duration)
    duration = duration or 3
    Rayfield:Notify({
        Title = title,
        Content = content,
        Duration = duration,
        Image = 4483362458,
    })
end

local function getCharacter()
    local char = player.Character
    if not char or not char.Parent then
        char = player.CharacterAdded:Wait()
    end
    return char
end

local function getHRP()
    local char = getCharacter()
    return char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = getCharacter()
    return char:FindFirstChild("Humanoid")
end

-- ==================== SAFE ZONE SYSTEM ====================

local function safeZoneLoop()
    state.tickIDs.safeZoneLoop = state.tickIDs.safeZoneLoop + 1
    local currentTickID = state.tickIDs.safeZoneLoop
    
    task.spawn(function()
        while currentTickID == state.tickIDs.safeZoneLoop do
            pcall(function()
                local hrp = getHRP()
                local hum = getHumanoid()
                
                if hrp and hum then
                    local kickPos = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild("KickReady")
                    
                    if kickPos then
                        local kickCFrame = kickPos:IsA("BasePart") and kickPos.CFrame or kickPos:GetPivot()
                        local distance = (hrp.Position - kickCFrame.Position).Magnitude
                        
                        -- Se estiver perto da zona segura
                        if distance < gameConfig.safeZoneRadius then
                            -- Andar devagar
                            hum.WalkSpeed = gameConfig.slowWalkSpeed
                            debugLog("Perto da zona - Velocidade lenta: " .. gameConfig.slowWalkSpeed)
                        else
                            -- Velocidade normal
                            if not state.speedEnabled then
                                hum.WalkSpeed = gameConfig.normalWalkSpeed
                            end
                        end
                    end
                end
            end)
            
            task.wait(0.1)
        end
    end)
end

-- ==================== ADVANCED BYPASS FUNCTIONS ====================

local function applyBypassLoop()
    state.tickIDs.bypassLoop = state.tickIDs.bypassLoop + 1
    local currentTickID = state.tickIDs.bypassLoop
    
    task.spawn(function()
        while currentTickID == state.tickIDs.bypassLoop do
            pcall(function()
                local hrp = getHRP()
                local hum = getHumanoid()
                local char = getCharacter()
                
                if hrp and hum and char then
                    -- Aplicar physics spoof
                    if gameConfig.usePhysicsSpoof then
                        PhysicsSpoof:apply(hrp)
                    end
                    
                    -- Aplicar humanoid spoof
                    if gameConfig.useHumanoidSpoof then
                        HumanoidSpoof:mask(hum)
                    end
                    
                    -- Aplicar animation desync
                    if gameConfig.useAnimationDesync then
                        AnimationDesync:apply(char)
                    end
                end
            end)
            
            task.wait(0.05)
        end
    end)
end

local function antiAFKLoop()
    state.tickIDs.antiAFKLoop = state.tickIDs.antiAFKLoop + 1
    local currentTickID = state.tickIDs.antiAFKLoop
    
    if not state.antiAFK then return end
    
    task.spawn(function()
        while state.antiAFK and currentTickID == state.tickIDs.antiAFKLoop do
            pcall(function()
                local hrp = getHRP()
                local hum = getHumanoid()
                
                if hrp and hum and hum.Health > 0 then
                    -- Movimento aleatório pequeno
                    AntiAFK:moveRandomly(hrp, hum)
                    
                    -- Pulo aleatório ocasional
                    AntiAFK:jumpRandomly(hum)
                    
                    -- Girar jogador ocasionalmente
                    if math.random() < 0.1 then
                        AntiAFK:turnPlayer(hrp)
                    end
                    
                    debugLog("Anti-AFK: Atividade detectada")
                end
            end)
            
            -- Fazer movimentos a cada 5-15 segundos
            task.wait(math.random(5, 15))
        end
    end)
end

local function safeTP(targetCFrame)
    if not gameConfig.teleportSafety then
        local hrp = getHRP()
        if hrp then
            hrp.CFrame = targetCFrame
        end
        return
    end
    
    local hrp = getHRP()
    if not hrp then return end
    
    pcall(function()
        if gameConfig.useTeleportSpoof then
            -- Usar teleporte gradual para evitar detecção
            TeleportSpoof:gradualTP(hrp, targetCFrame)
        else
            hrp.Velocity = Vector3.new(0, 0, 0)
            hrp.CFrame = targetCFrame
        end
    end)
end

local function smoothFly(targetPos, speedOverride)
    local hrp = getHRP()
    local hum = getHumanoid()
    
    if not (hrp and hum and hum.Health > 0) then return false end
    
    local targetCFrame = CFrame.new(targetPos.X, gameConfig.fixedYPos, targetPos.Z)
    local dist = (hrp.Position - targetCFrame.Position).Magnitude
    local flySpeed = speedOverride or (state.speedEnabled and state.customSpeed or math.max(hum.WalkSpeed, 50))
    local timeToFly = math.max(dist / flySpeed, 0.1)
    
    pcall(function()
        if gameConfig.useTeleportSpoof then
            TeleportSpoof:gradualTP(hrp, targetCFrame)
        else
            hrp.Anchored = true
            local tween = TweenService:Create(hrp, TweenInfo.new(timeToFly, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
            tween:Play()
            tween.Completed:Wait()
            if hrp and hrp.Parent then
                hrp.Anchored = false
            end
        end
    end)
    
    return true
end

local function forceClick(target)
    if not target or not target.Parent then return end
    
    pcall(function()
        if getconnections then
            for _, c in pairs(getconnections(target.MouseButton1Down)) do c:Fire() end
            for _, c in pairs(getconnections(target.MouseButton1Click)) do c:Fire() end
            for _, c in pairs(getconnections(target.Activated)) do c:Fire() end
        end
    end)
    
    pcall(function()
        if firesignal then
            firesignal(target.MouseButton1Down)
            firesignal(target.MouseButton1Click)
            firesignal(target.Activated)
        end
    end)
    
    pcall(function()
        if target:IsA("GuiButton") then
            target:Activate()
        end
    end)
    
    pcall(function()
        if target:IsA("GuiObject") and target.AbsoluteSize.X > 0 and target.Visible then
            local vim = game:GetService("VirtualInputManager")
            local guiInset = game:GetService("GuiService"):GetGuiInset()
            local clickX = target.AbsolutePosition.X + (target.AbsoluteSize.X / 2) + guiInset.X
            local clickY = target.AbsolutePosition.Y + (target.AbsoluteSize.Y / 2) + guiInset.Y
            
            vim:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
            task.wait(gameConfig.useRequestTiming and RequestTiming:getDelay() or 0.01)
            vim:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
        end
    end)
end

-- ==================== AUTO SYSTEMS WITH BYPASS ====================

local function autoKickSystem()
    state.tickIDs.autoKick = state.tickIDs.autoKick + 1
    local currentTickID = state.tickIDs.autoKick
    
    if not state.autoKick then return end
    
    task.spawn(function()
        while state.autoKick and currentTickID == state.tickIDs.autoKick do
            pcall(function()
                local hrp = getHRP()
                local hum = getHumanoid()
                
                if not (hrp and hum and hum.Health > 0) then return end
                
                local kickPos = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild("KickReady")
                if not kickPos then return end
                
                local targetCF = kickPos:IsA("BasePart") and kickPos.CFrame or kickPos:GetPivot()
                
                if (hrp.Position - targetCF.Position).Magnitude > 5 then
                    safeTP(targetCF + Vector3.new(0, 3, 0))
                end
                
                task.wait(gameConfig.useNetworkDelay and NetworkDelay:apply() or 0.5)
                local startPos = hrp.Position
                local wasTeleported = false
                local HUD = PlayerGui:FindFirstChild("HUD")
                
                for i = 1, 150 do
                    task.wait(0.1)
                    
                    if not (hrp and hrp.Parent) or hum.Health <= 0 then return end
                    
                    if (hrp.Position - startPos).Magnitude > 30 then
                        wasTeleported = true
                        break
                    end
                    
                    local KickButton = HUD and HUD:FindFirstChild("KickButton")
                    if KickButton and KickButton.Visible and Net then
                        -- NOVO: Verificar cooldown de 2 segundos
                        local currentTime = tick()
                        if currentTime - state.lastKickTime < state.kickCooldown then
                            task.wait(0.5)
                            continue
                        end
                        
                        -- Usar detecção evasão para variar chutes
                        if gameConfig.useDetectionEvasion and not DetectionEvasion:shouldKick() then
                            task.wait(0.5)
                            continue
                        end
                        
                        local kickMode = gameConfig.useDetectionEvasion and DetectionEvasion:getRandomKickMode() or state.kickMode
                        debugLog("Chute: " .. kickMode .. " | Cooldown até: " .. string.format("%.1f", state.kickCooldown) .. "s")
                        
                        Net.rev_KickEvent:FireServer(kickValues[kickMode] or 1)
                        state.totalKicks = state.totalKicks + 1
                        state.lastKickTime = currentTime -- NOVO: Atualizar tempo do último chute
                        
                        task.wait(gameConfig.useRequestTiming and RequestTiming:getDelay() or 0.5)
                    end
                end
                
                if not wasTeleported then return end
                task.wait(gameConfig.useNetworkDelay and NetworkDelay:apply() or 0.5)
                
                local spawnedMonster = nil
                local hasMonster = false
                
                for i = 1, 40 do
                    task.wait(0.2)
                    
                    local closestDist = 60
                    
                    for _, obj in pairs(workspace.Debris:GetChildren()) do
                        if obj:IsA("Model") and obj.PrimaryPart then
                            local dist = (obj.PrimaryPart.Position - hrp.Position).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                hasMonster = true
                                spawnedMonster = obj
                            end
                        end
                    end
                    
                    if hasMonster then break end
                end
                
                if not (hasMonster and spawnedMonster) then return end
                task.wait(gameConfig.useNetworkDelay and NetworkDelay:apply() or 0.5)
                
                local isDesired = false
                local hasSelection = false
                
                for mut, isActive in pairs(state.targetMutations) do
                    if isActive then
                        hasSelection = true
                        
                        if mut == "Normal" then
                            isDesired = true
                            break
                        end
                        
                        for _, child in pairs(spawnedMonster:GetChildren()) do
                            if string.find(string.lower(child.Name), string.lower(mut)) then
                                isDesired = true
                                break
                            end
                        end
                        
                        if isDesired then break end
                    end
                end
                
                if hasSelection and not isDesired then
                    local waves = workspace:FindFirstChild("Waves")
                    local wavePos = nil
                    
                    if waves then
                        if waves:IsA("BasePart") then
                            wavePos = waves.Position
                        elseif waves:IsA("Model") then
                            wavePos = waves:GetPivot().Position
                        else
                            local part = waves:FindFirstChildWhichIsA("BasePart", true)
                            if part then wavePos = part.Position end
                        end
                    end
                    
                    if wavePos then
                        debugLog("Monster indesejado - Fugindo")
                        smoothFly(wavePos)
                    else
                        smoothFly(targetCF.Position)
                    end
                else
                    debugLog("Monster desejado - Voltando")
                    smoothFly(targetCF.Position)
                end
                
            end)
            
            task.wait(gameConfig.autoRetryDelay)
        end
    end)
end

local function autoTrainSystem()
    state.tickIDs.autoTrain = state.tickIDs.autoTrain + 1
    local currentTickID = state.tickIDs.autoTrain
    
    if not state.autoTrain then return end
    
    task.spawn(function()
        while state.autoTrain and currentTickID == state.tickIDs.autoTrain do
            pcall(function()
                local char = getCharacter()
                local hum = char:FindFirstChild("Humanoid")
                local backpack = player:FindFirstChild("Backpack")
                local currentTool = char:FindFirstChildOfClass("Tool")
                
                if not currentTool then
                    local slot1 = PlayerGui:FindFirstChild("Backpack")
                        and PlayerGui.Backpack:FindFirstChild("Bar")
                        and PlayerGui.Backpack.Bar:FindFirstChild("Slot1")
                    
                    if slot1 then
                        forceClick(slot1)
                        if slot1:FindFirstChild("ToolImage") then
                            forceClick(slot1.ToolImage)
                        end
                    end
                    
                    task.wait(gameConfig.useNetworkDelay and NetworkDelay:apply() or 0.1)
                    
                    if not char:FindFirstChildOfClass("Tool") and backpack and hum then
                        for _, tool in pairs(backpack:GetChildren()) do
                            if tool:IsA("Tool") and validWeights[tool.Name] then
                                hum:EquipTool(tool)
                                break
                            end
                        end
                    end
                else
                    currentTool:Activate()
                end
                
            end)
            
            pcall(function()
                local kickUpgrades = PlayerGui:FindFirstChild("KickUpgrades")
                if kickUpgrades then
                    for _, bonus in pairs(kickUpgrades:GetChildren()) do
                        if (bonus.Name == "Bonus" or bonus.Name == "PopBonus") and bonus.Visible then
                            forceClick(bonus)
                            for _, child in ipairs(bonus:GetDescendants()) do
                                if child:IsA("GuiButton") or child:IsA("ImageLabel") then
                                    forceClick(child)
                                end
                            end
                        end
                    end
                end
            end)
            
            task.wait(gameConfig.useNetworkDelay and NetworkDelay:apply() or 0.1)
        end
    end)
end

local function autoCollectSystem()
    state.tickIDs.autoCollect = state.tickIDs.autoCollect + 1
    local currentTickID = state.tickIDs.autoCollect
    
    if not state.autoCollect then return end
    
    task.spawn(function()
        local hrp = getHRP()
        
        if not state.lockedPlot and hrp then
            local closestDist = math.huge
            for _, plot in pairs(workspace:WaitForChild("Plots"):GetChildren()) do
                if plot:IsA("Model") or plot:IsA("Folder") then
                    local dist = (hrp.Position - plot:GetPivot().Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        state.lockedPlot = plot
                    end
                end
            end
        end
        
        while state.autoCollect and currentTickID == state.tickIDs.autoCollect do
            pcall(function()
                if state.lockedPlot then
                    local buttonsFolder = state.lockedPlot:FindFirstChild("Buttons")
                    if buttonsFolder then
                        for i = 1, 30 do
                            if not state.autoCollect or currentTickID ~= state.tickIDs.autoCollect then break end
                            
                            local slotPart = buttonsFolder:FindFirstChild("Slot" .. i)
                            if slotPart then
                                local targetCFrame
                                
                                if slotPart:IsA("BasePart") then
                                    targetCFrame = slotPart.CFrame
                                elseif slotPart:IsA("Model") and slotPart.PrimaryPart then
                                    targetCFrame = slotPart.PrimaryPart.CFrame
                                else
                                    local part = slotPart:FindFirstChildWhichIsA("BasePart")
                                    if part then targetCFrame = part.CFrame end
                                end
                                
                                if targetCFrame then
                                    safeTP(targetCFrame + Vector3.new(0, 1.5, 0))
                                    task.wait(gameConfig.useNetworkDelay and NetworkDelay:apply() or 0.1)
                                    
                                    if Net then
                                        Net.rev_B_Collect:FireServer(i)
                                        state.totalCollected = state.totalCollected + 1
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            
            task.wait(1.5)
        end
    end)
end

local function autoUpgradeSystem()
    state.tickIDs.autoUpgrade = state.tickIDs.autoUpgrade + 1
    local currentTickID = state.tickIDs.autoUpgrade
    
    if not state.autoUpgrade then return end
    
    task.spawn(function()
        while state.autoUpgrade and currentTickID == state.tickIDs.autoUpgrade do
            pcall(function()
                if Net then
                    Net.rev_B_Upgrade:FireServer(tonumber(state.targetUpgrade) or 1)
                    state.totalUpgrades = state.totalUpgrades + 1
                end
            end)
            
            task.wait(gameConfig.useRequestTiming and RequestTiming:getDelay() or 0.2)
        end
    end)
end

local function autoBuyWeightSystem()
    state.tickIDs.autoBuyWeight = state.tickIDs.autoBuyWeight + 1
    local currentTickID = state.tickIDs.autoBuyWeight
    
    if not state.autoBuyWeight then return end
    
    task.spawn(function()
        while state.autoBuyWeight and currentTickID == state.tickIDs.autoBuyWeight do
            pcall(function()
                if Net then
                    local cleanName = string.match(state.targetWeight, "^(.-)%s+%S+$") or state.targetWeight
                    Net.rev_Shop_Buy:FireServer("WeightShop", cleanName)
                end
            end)
            
            task.wait(gameConfig.useRequestTiming and RequestTiming:getDelay() or 0.5)
        end
    end)
end

local function autoBrainrotSystem()
    state.tickIDs.autoBrainrot = state.tickIDs.autoBrainrot + 1
    local currentTickID = state.tickIDs.autoBrainrot
    
    if not state.autoBrainrot then return end
    
    task.spawn(function()
        while state.autoBrainrot and currentTickID == state.tickIDs.autoBrainrot do
            pcall(function()
                local hrp = getHRP()
                local hum = getHumanoid()
                
                if not (hrp and hum and hum.Health > 0) then return end
                
                -- Procurar por Brainrot no workspace
                local brainrotFound = false
                
                for _, debris in pairs(workspace.Debris:GetChildren()) do
                    if debris:IsA("Model") and string.find(string.lower(debris.Name), "brainrot") then
                        local brainrotPart = debris.PrimaryPart or debris:FindFirstChildWhichIsA("BasePart")
                        
                        if brainrotPart then
                            -- Teleportar para o Brainrot (mais alto)
                            local targetCFrame = brainrotPart.CFrame + Vector3.new(0, 10, 0)
                            safeTP(targetCFrame)
                            
                            task.wait(1)
                            
                            -- Interagir com o Brainrot (tentar pegar)
                            if Net then
                                -- Procurar event de coleta similar ao usado em KickReady
                                pcall(function()
                                    -- Tenta pegar direto com proximity
                                    local proximity = debris:FindFirstChildOfClass("ProximityPrompt")
                                    if proximity then
                                        proximity:InputHoldBegin()
                                        task.wait(0.1)
                                        proximity:InputHoldEnd()
                                    end
                                end)
                                
                                -- Fallback: enviar comando de coleta genérico
                                pcall(function()
                                    if Net.rev_PickupItem then
                                        Net.rev_PickupItem:FireServer(debris)
                                    end
                                end)
                                
                                -- Outro fallback: usar evento de toque
                                pcall(function()
                                    if debris:FindFirstChild("TouchInterest") then
                                        for _, touchPart in pairs(debris:GetChildren()) do
                                            if touchPart:IsA("BasePart") then
                                                firetouchinterest(hrp, touchPart, 0)
                                                task.wait(0.1)
                                                firetouchinterest(hrp, touchPart, 1)
                                            end
                                        end
                                    end
                                end)
                            end
                            
                            brainrotFound = true
                            state.totalBrainrot = state.totalBrainrot + 1
                            notify("✅ Brainrot", "Brainrot coletado!", 1)
                            
                            task.wait(1)
                            break
                        end
                    end
                end
                
                if not brainrotFound then
                    -- Se não achou, volta para KickReady
                    local kickPos = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild("KickReady")
                    if kickPos then
                        local targetCF = kickPos:IsA("BasePart") and kickPos.CFrame or kickPos:GetPivot()
                        safeTP(targetCF + Vector3.new(0, 3, 0))
                    end
                end
                
            end)
            
            task.wait(2) -- Procurar a cada 2 segundos
        end
    end)
end

local function speedControlSystem()
    state.tickIDs.speedControl = state.tickIDs.speedControl + 1
    local currentTickID = state.tickIDs.speedControl
    
    if not state.speedEnabled then return end
    
    task.spawn(function()
        while state.speedEnabled and currentTickID == state.tickIDs.speedControl do
            pcall(function()
                local hum = getHumanoid()
                if hum then
                    hum.WalkSpeed = state.customSpeed
                end
            end)
            
            task.wait(0.1)
        end
    end)
end

