            if gameConfig.useAnimationDesync then info = info .. "✓ Animation Desync\n" count = count + 1 end
            if state.antiAFK then info = info .. "✓ Anti-AFK\n" count = count + 1 end
            
            info = info .. "\n📊 Proteções: " .. count .. "/8"
            
            bypassStatsLabel:Set(info)
        end)
    end
end)

